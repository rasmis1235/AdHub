# ============================================================
# AdHub Backend Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ============================================================

NODE_ENV=development
PORT=8000

# ---- PostgreSQL ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adhub
DB_USER=adhub_user
DB_PASSWORD=your_strong_password_here
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ---- JWT (generate with: openssl rand -hex 32) ----
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_string_here_change_me_now
JWT_REFRESH_SECRET=another_64_char_random_hex_string_here_different_from_above
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ---- Google OAuth (console.cloud.google.com) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=AdHub <noreply@adhub.in>

# ---- App URLs ----
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000

# ---- Encryption (generate with: openssl rand -hex 32) ----
ENCRYPTION_KEY=replace_with_32_char_key_for_encrypting_account_details_here

# ---- IP Geolocation ----
# Sign up at ipinfo.io for a free token (50k requests/month)
IPINFO_TOKEN=

# ---- AWS S3 (optional - for media uploads) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=adhub-media

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- Feature Flags ----
WITHDRAWAL_ENABLED=true
REFERRAL_ENABLED=true
FRAUD_DETECTION_ENABLED=true
