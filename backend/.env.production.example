# ── Copy this to Railway environment variables ────────────────────────────
# DO NOT commit real secrets. Fill in values in Railway dashboard.

NODE_ENV=production
PORT=8080

# Railway provides this automatically when you add a PostgreSQL service
DATABASE_URL=postgresql://user:pass@host:5432/adhub

# Upstash Redis (free tier) — get from upstash.com
REDIS_URL=rediss://default:TOKEN@ENDPOINT.upstash.io:6379

# JWT — generate new secrets for production (keep different from dev)
JWT_ACCESS_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Gmail SMTP (same as dev is fine)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rasmis1235@gmail.com
SMTP_PASS=YOUR_APP_PASSWORD
SMTP_FROM=AdHub <noreply@rasmis1235.tech>

# Domain URLs
APP_URL=https://rasmis1235.tech
API_URL=https://api.rasmis1235.tech
ALLOWED_ORIGINS=https://rasmis1235.tech,https://www.rasmis1235.tech

# SSL
DB_SSL=true

# Encryption — generate new key for production
ENCRYPTION_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX

# Feature flags
WITHDRAWAL_ENABLED=true
REFERRAL_ENABLED=true
FRAUD_DETECTION_ENABLED=true

# Rate limiting (stricter in production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
